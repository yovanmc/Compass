<Page x:Class="Compass.App.Views.RecommendView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:controls="clr-namespace:Compass.App.Controls"
      xmlns:vm="clr-namespace:Compass.App.ViewModels"
      mc:Ignorable="d"
      Background="#0A0A0A"
      d:DataContext="{d:DesignInstance vm:RecommendViewModel}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ SECTION HEADER ═══════════════════════════════════════════ -->
        <Border Grid.Row="0" Padding="16,10,16,0">
            <TextBlock Text="Recommended from your backlog"
                       Foreground="#EAEAEA" FontSize="14" FontWeight="SemiBold"/>
        </Border>

        <!-- ═══ MAIN CONTENT ════════════════════════════════════════════ -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                      Background="#0A0A0A" Padding="16,6,16,0">
            <StackPanel>

                <!-- Empty state -->
                <TextBlock Foreground="#5F5F5F" FontSize="13" Margin="0,4,0,16"
                           Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}"
                           Text="No recommendations yet — sync your library to get started."/>

                <!-- Recommendations card grid -->
                <ItemsControl ItemsSource="{Binding Recommendations, Mode=OneWay}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:RecommendationRow}">
                            <Border Margin="0,0,10,10"
                                    Width="210"
                                    Background="#141414"
                                    BorderBrush="#242424" BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="10,10,12,12"
                                    Cursor="Hand">
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftClick"
                                                  Command="{Binding DataContext.OpenDetailCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                  CommandParameter="{Binding}"/>
                                </Border.InputBindings>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <controls:ScoreRing Grid.Column="0"
                                                        Percent="{Binding ScorePercent, Mode=OneWay}"
                                                        Margin="0,0,10,0"
                                                        VerticalAlignment="Top"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Top">
                                        <TextBlock Text="{Binding Name, Mode=OneWay}"
                                                   Foreground="#EAEAEA" FontSize="13"
                                                   FontWeight="Medium"
                                                   TextWrapping="Wrap"
                                                   LineHeight="18"/>
                                        <TextBlock Text="{Binding FeatureLine, Mode=OneWay}"
                                                   Foreground="#8A8A8A" FontSize="11"
                                                   TextWrapping="Wrap"
                                                   Margin="0,3,0,0"
                                                   LineHeight="15"/>
                                        <TextBlock Text="{Binding Why, Mode=OneWay}"
                                                   Foreground="#5F5F5F" FontSize="11"
                                                   TextWrapping="Wrap"
                                                   Margin="0,3,0,0"
                                                   FontStyle="Italic"
                                                   LineHeight="15"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Unmatched section -->
                <Expander IsExpanded="False" Margin="0,16,0,8"
                          Background="Transparent" BorderThickness="0">
                    <Expander.Header>
                        <TextBlock Foreground="#8A8A8A" FontSize="13">
                            <Run Text="Unmatched ("/>
                            <Run Text="{Binding Unmatched.Count, Mode=OneWay}"/>
                            <Run Text=")"/>
                        </TextBlock>
                    </Expander.Header>
                    <ItemsControl ItemsSource="{Binding Unmatched, Mode=OneWay}" Margin="0,8,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:GameRow}">
                                <TextBlock Text="{Binding Name, Mode=OneWay}"
                                           Foreground="#5F5F5F" FontSize="12"
                                           Margin="0,2"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Expander>

            </StackPanel>
        </ScrollViewer>

        <!-- ═══ FOOTER ═══════════════════════════════════════════════════ -->
        <Border Grid.Row="2" Background="#0D0D0D" BorderBrush="#222" BorderThickness="0,1,0,0"
                Padding="16,6">
            <TextBlock Foreground="#5F5F5F" FontSize="11">
                <Run Text="Backlog ("/>
                <Run Text="{Binding Recommendations.Count, Mode=OneWay}"/>
                <Run Text=") · Unmatched ("/>
                <Run Text="{Binding Unmatched.Count, Mode=OneWay}"/>
                <Run Text=")"/>
            </TextBlock>
        </Border>
    </Grid>
</Page>
