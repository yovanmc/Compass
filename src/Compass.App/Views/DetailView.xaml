<UserControl x:Class="Compass.App.Views.DetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Compass.App.ViewModels"
             mc:Ignorable="d"
             Background="#0F0F0F"
             d:DataContext="{d:DesignInstance vm:DetailViewModel}">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="0,0,0,24">

            <!-- ═══ COVER ART ═════════════════════════════════════════════════ -->
            <!-- #222 placeholder always underlies; image overlays when path is available -->
            <Border Height="360" Background="#222">
                <Grid>
                    <!-- Placeholder label: visible when no cover -->
                    <TextBlock Text="No cover"
                               Foreground="#5F5F5F" FontSize="12"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Visibility="{Binding CoverPath, Converter={StaticResource NullToVis}, ConverterParameter=invert}"/>

                    <!-- Cover image: visible when CoverPath is non-null -->
                    <Image Stretch="UniformToFill"
                           Visibility="{Binding CoverPath, Converter={StaticResource NullToVis}}"
                           Source="{Binding CoverPath, Converter={StaticResource PathToImageConverter}}"/>
                </Grid>
            </Border>

            <!-- ═══ METADATA ══════════════════════════════════════════════════ -->
            <StackPanel Margin="16,14,16,0">

                <!-- Game name -->
                <TextBlock Text="{Binding Name, Mode=OneWay}"
                           Foreground="#EAEAEA"
                           FontSize="18" FontWeight="Bold"
                           TextWrapping="Wrap"
                           LineHeight="24"
                           Margin="0,0,0,6"/>

                <!-- Status pill + playtime row -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">

                    <!-- Status pill -->
                    <Border CornerRadius="10" Padding="8,3" Margin="0,0,8,0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#2A2A2A"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding StatusLabel}" Value="Played">
                                        <Setter Property="Background" Value="#1A3320"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding StatusLabel}" Value="Backlog">
                                        <Setter Property="Background" Value="#1E2840"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding StatusLabel}" Value="Unmatched">
                                        <Setter Property="Background" Value="#2A2010"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding StatusLabel}" Value="Hidden">
                                        <Setter Property="Background" Value="#2A1A1A"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding StatusLabel, Mode=OneWay}" FontSize="11" FontWeight="Medium">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#5F5F5F"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding StatusLabel}" Value="Played">
                                            <Setter Property="Foreground" Value="#4CAF50"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding StatusLabel}" Value="Backlog">
                                            <Setter Property="Foreground" Value="#4FC3F7"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding StatusLabel}" Value="Unmatched">
                                            <Setter Property="Foreground" Value="#EBB740"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding StatusLabel}" Value="Hidden">
                                            <Setter Property="Foreground" Value="#8A4A4A"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>

                    <!-- Playtime (forever) -->
                    <TextBlock Text="{Binding PlaytimeForeverDisplay, Mode=OneWay}"
                               Foreground="#8A8A8A" FontSize="12"
                               VerticalAlignment="Center"/>

                </StackPanel>

                <!-- Playtime (recent) — only if non-empty -->
                <TextBlock Foreground="#5F5F5F" FontSize="11" Margin="0,0,0,6"
                           Text="{Binding Playtime2WeeksDisplay, Mode=OneWay}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Playtime2WeeksDisplay}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- Match label -->
                <TextBlock Text="{Binding MatchLabel, Mode=OneWay}"
                           Foreground="#5F5F5F" FontSize="11" FontStyle="Italic"
                           Margin="0,0,0,14"/>

                <!-- ── Score section (only when HasScore) ─────────────────── -->
                <StackPanel Margin="0,0,0,14"
                            Visibility="{Binding HasScore, Converter={StaticResource BoolToVis}}">

                    <!-- Score % -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="{Binding ScorePercent, Mode=OneWay}"
                                   Foreground="#EBB740" FontSize="28" FontWeight="Bold"/>
                        <TextBlock Text="%" Foreground="#EBB740" FontSize="16"
                                   VerticalAlignment="Bottom" Margin="2,0,0,4"/>
                        <TextBlock Text="match score"
                                   Foreground="#5F5F5F" FontSize="12"
                                   VerticalAlignment="Bottom" Margin="8,0,0,5"/>
                    </StackPanel>

                    <!-- Top factors label -->
                    <TextBlock Text="Top factors"
                               Foreground="#8A8A8A" FontSize="11" FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <!-- TopFeatures bars (rank-ordered by contribution, width ∝ magnitude) -->
                    <ItemsControl ItemsSource="{Binding TopFeatures, Mode=OneWay}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- Feature name -->
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Name, Mode=OneWay}"
                                               Foreground="#4FC3F7" FontSize="11"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="0,0,10,0"/>
                                    <!-- Bar track (fixed 180px) with cyan fill proportional to Fraction -->
                                    <Border Grid.Column="1" Width="180" Height="6"
                                            Background="#141414" CornerRadius="3"
                                            HorizontalAlignment="Right" VerticalAlignment="Center">
                                        <Border Background="#4FC3F7" CornerRadius="3"
                                                HorizontalAlignment="Left"
                                                Width="{Binding Fraction, Converter={StaticResource FractionToWidth}, ConverterParameter=180}"/>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Because you played -->
                    <StackPanel Margin="0,8,0,0">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding NearestLoved.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="Because you played"
                                   Foreground="#8A8A8A" FontSize="11" FontWeight="SemiBold"
                                   Margin="0,0,0,6"/>
                        <ItemsControl ItemsSource="{Binding NearestLoved, Mode=OneWay}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#1A3320" CornerRadius="10" Padding="8,3" Margin="0,0,6,6">
                                        <TextBlock Text="{Binding Mode=OneWay}"
                                                   Foreground="#4CAF50" FontSize="11"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Held back by (only if non-empty) -->
                    <StackPanel Margin="0,8,0,0">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <!-- Default visible; collapsed when count is 0 -->
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding PenalizedBy.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="Held back by"
                                   Foreground="#8A8A8A" FontSize="11" FontWeight="SemiBold"
                                   Margin="0,0,0,6"/>
                        <ItemsControl ItemsSource="{Binding PenalizedBy, Mode=OneWay}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#2A1A1A" CornerRadius="10" Padding="8,3" Margin="0,0,6,6">
                                        <TextBlock Text="{Binding Mode=OneWay}"
                                                   Foreground="#8A4A4A" FontSize="11"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                </StackPanel>

                <!-- ── SEPARATOR ────────────────────────────────────────────── -->
                <Border Height="1" Background="#222" Margin="0,0,0,14"/>

                <!-- ── FEATURE GROUPS ──────────────────────────────────────── -->
                <ItemsControl ItemsSource="{Binding FeatureGroups, Mode=OneWay}" Margin="0,0,0,6">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:FeatureGroup}">
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="{Binding Category, Mode=OneWay}"
                                           Foreground="#8A8A8A" FontSize="11" FontWeight="SemiBold"
                                           Margin="0,0,0,6"/>
                                <ItemsControl ItemsSource="{Binding Items, Mode=OneWay}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#141414" BorderBrush="#2A2A2A" BorderThickness="1"
                                                    CornerRadius="10" Padding="8,3" Margin="0,0,6,6">
                                                <TextBlock Text="{Binding Mode=OneWay}"
                                                           Foreground="#8A8A8A" FontSize="11"/>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- ── SEPARATOR ────────────────────────────────────────────── -->
                <Border Height="1" Background="#222" Margin="0,4,0,14"/>

                <!-- ── NOT INTERESTED toggle ──────────────────────────────── -->
                <Button Command="{Binding ToggleNotInterestedCommand}"
                        Cursor="Hand"
                        Padding="12,7"
                        FontSize="13"
                        HorizontalAlignment="Left"
                        BorderThickness="1">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#2A1A1A"/>
                            <Setter Property="Foreground" Value="#8A4A4A"/>
                            <Setter Property="BorderBrush" Value="#3A2020"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="6"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#3A2020"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsNotInterested}" Value="True">
                                    <Setter Property="Background" Value="#1A1A2A"/>
                                    <Setter Property="Foreground" Value="#4FC3F7"/>
                                    <Setter Property="BorderBrush" Value="#222240"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <TextBlock>
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="Hide this game"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsNotInterested}" Value="True">
                                        <Setter Property="Text" Value="Unhide this game"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Button>

                <!-- ── MORE LIKE THIS (only when HasSimilar) ──────────────── -->
                <StackPanel Margin="0,14,0,0"
                            Visibility="{Binding HasSimilar, Converter={StaticResource BoolToVis}}">
                    <Border Height="1" Background="#222" Margin="0,0,0,14"/>
                    <TextBlock Text="More like this"
                               Foreground="#8A8A8A" FontSize="11" FontWeight="SemiBold"
                               Margin="0,0,0,8"/>
                    <ItemsControl ItemsSource="{Binding Similar, Mode=OneWay}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><WrapPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="120" Margin="0,0,8,8"
                                        Background="#141414" BorderBrush="#2A2A2A" BorderThickness="1"
                                        CornerRadius="6" Padding="8,7"
                                        Cursor="Hand"
                                        MouseLeftButtonUp="Similar_Click">
                                    <StackPanel>
                                        <!-- cover placeholder (thumbs deferred) -->
                                        <Border Height="56" Background="#222" CornerRadius="4" Margin="0,0,0,6"/>
                                        <TextBlock Text="{Binding Name, Mode=OneWay}"
                                                   Foreground="#EAEAEA" FontSize="11"
                                                   TextWrapping="Wrap" MaxHeight="30"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Foreground="#4FC3F7" FontSize="10" Margin="0,3,0,0">
                                            <Run Text="{Binding ScorePercent, Mode=OneWay}"/><Run Text="% match"/>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
