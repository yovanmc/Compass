<ui:FluentWindow x:Class="Compass.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:controls="clr-namespace:Compass.App.Controls"
        xmlns:vm="clr-namespace:Compass.App.ViewModels"
        mc:Ignorable="d"
        Title="Compass" Height="720" Width="1100"
        MinHeight="500" MinWidth="700"
        WindowBackdropType="None"
        Background="#0A0A0A"
        ExtendsContentIntoTitleBar="True"
        d:DataContext="{d:DesignInstance vm:MainViewModel}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ TITLE BAR ════════════════════════════════════════════════ -->
        <ui:TitleBar Grid.Row="0"
                     Title="Compass"
                     Background="#0A0A0A"
                     Foreground="#EAEAEA">
            <ui:TitleBar.Header>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="&#x2BC7;"
                               Foreground="#4FC3F7"
                               FontSize="18"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"/>
                    <TextBlock Text="Compass"
                               FontSize="16" FontWeight="SemiBold"
                               Foreground="#EAEAEA"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </ui:TitleBar.Header>
            <ui:TitleBar.TrailingContent>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                    <ui:Button Content="⟳  Sync"
                               Command="{Binding SyncCommand}"
                               IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"
                               Appearance="Primary"
                               Padding="14,6"
                               FontWeight="SemiBold"
                               FontSize="13"
                               Margin="0,0,12,0"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding StatusText, Mode=OneWay}"
                               Foreground="#8A8A8A" FontSize="12"
                               VerticalAlignment="Center" MaxWidth="320"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>
            </ui:TitleBar.TrailingContent>
        </ui:TitleBar>

        <!-- ═══ MISSING-KEYS BANNER ══════════════════════════════════════ -->
        <Border Grid.Row="1"
                Margin="16,6,16,0"
                Padding="14,10"
                Background="#0D1A22"
                BorderBrush="#4FC3F7"
                BorderThickness="1"
                CornerRadius="6"
                Visibility="{Binding HasMissingSecrets, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <TextBlock Text="Add your Steam / IGDB API keys to sync — see README"
                           Foreground="#4FC3F7" FontSize="13" FontWeight="SemiBold"
                           Margin="0,0,0,4"/>
                <ItemsControl ItemsSource="{Binding MissingSecrets, Mode=OneWay}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock FontSize="11" Foreground="#8A8A8A">
                                <Run Text="• "/>
                                <Run Text="{Binding Mode=OneWay}"/>
                            </TextBlock>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!-- ═══ SECTION HEADER ═══════════════════════════════════════════ -->
        <Border Grid.Row="2" Padding="16,10,16,0">
            <TextBlock Text="Recommended from your backlog"
                       Foreground="#EAEAEA" FontSize="14" FontWeight="SemiBold"/>
        </Border>

        <!-- ═══ MAIN CONTENT ══════════════════════════════════════════════ -->
        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto"
                      Background="#0A0A0A" Padding="16,6,16,0">
            <StackPanel>

                <!-- Empty state -->
                <TextBlock Foreground="#5F5F5F" FontSize="13" Margin="0,4,0,16"
                           Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}"
                           Text="No recommendations yet — sync your library to get started."/>

                <!-- Recommendations card grid -->
                <ItemsControl ItemsSource="{Binding Recommendations, Mode=OneWay}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:RecommendationRow}">
                            <Border Margin="0,0,10,10"
                                    Width="210"
                                    Background="#141414"
                                    BorderBrush="#242424" BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="10,10,12,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <controls:ScoreRing Grid.Column="0"
                                                        Percent="{Binding ScorePercent, Mode=OneWay}"
                                                        Margin="0,0,10,0"
                                                        VerticalAlignment="Top"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Top">
                                        <TextBlock Text="{Binding Name, Mode=OneWay}"
                                                   Foreground="#EAEAEA" FontSize="13"
                                                   FontWeight="Medium"
                                                   TextWrapping="Wrap"
                                                   LineHeight="18"/>
                                        <TextBlock Text="{Binding FeatureLine, Mode=OneWay}"
                                                   Foreground="#8A8A8A" FontSize="11"
                                                   TextWrapping="Wrap"
                                                   Margin="0,3,0,0"
                                                   LineHeight="15"/>
                                        <TextBlock Text="{Binding Why, Mode=OneWay}"
                                                   Foreground="#5F5F5F" FontSize="11"
                                                   TextWrapping="Wrap"
                                                   Margin="0,3,0,0"
                                                   FontStyle="Italic"
                                                   LineHeight="15"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Unmatched section -->
                <Expander IsExpanded="False" Margin="0,16,0,8"
                          Background="Transparent" BorderThickness="0">
                    <Expander.Header>
                        <TextBlock Foreground="#8A8A8A" FontSize="13">
                            <Run Text="Unmatched ("/>
                            <Run Text="{Binding Unmatched.Count, Mode=OneWay}"/>
                            <Run Text=")"/>
                        </TextBlock>
                    </Expander.Header>
                    <ItemsControl ItemsSource="{Binding Unmatched, Mode=OneWay}" Margin="0,8,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:GameRow}">
                                <TextBlock Text="{Binding Name, Mode=OneWay}"
                                           Foreground="#5F5F5F" FontSize="12"
                                           Margin="0,2"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Expander>
            </StackPanel>
        </ScrollViewer>

        <!-- ═══ FOOTER ════════════════════════════════════════════════════ -->
        <Border Grid.Row="4" Background="#0D0D0D" BorderBrush="#222" BorderThickness="0,1,0,0"
                Padding="16,6">
            <TextBlock Foreground="#5F5F5F" FontSize="11">
                <Run Text="Backlog ("/>
                <Run Text="{Binding Recommendations.Count, Mode=OneWay}"/>
                <Run Text=") · Unmatched ("/>
                <Run Text="{Binding Unmatched.Count, Mode=OneWay}"/>
                <Run Text=")"/>
            </TextBlock>
        </Border>
    </Grid>

</ui:FluentWindow>
