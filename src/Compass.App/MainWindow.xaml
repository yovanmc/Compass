<ui:FluentWindow x:Class="Compass.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:controls="clr-namespace:Compass.App.Controls"
        xmlns:vm="clr-namespace:Compass.App.ViewModels"
        mc:Ignorable="d"
        Title="Compass" Height="720" Width="1100"
        MinHeight="500" MinWidth="700"
        WindowBackdropType="None"
        Background="#0A0A0A"
        ExtendsContentIntoTitleBar="True"
        d:DataContext="{d:DesignInstance vm:MainViewModel}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- top bar / title bar area -->
            <RowDefinition Height="Auto"/>
            <!-- missing-keys banner -->
            <RowDefinition Height="*"/>
            <!-- main content -->
            <RowDefinition Height="Auto"/>
            <!-- footer -->
        </Grid.RowDefinitions>

        <!-- ═══ TOP BAR ══════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="#0A0A0A" Padding="16,10,16,10">
            <ui:TitleBar Title="Compass"
                         Background="Transparent"
                         Foreground="#EAEAEA"
                         MinHeight="40">
                <ui:TitleBar.Header>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- Compass icon (Unicode compass = &#x1F9ED; fallback Segoe UI Symbol) -->
                        <TextBlock Text="&#x2B;"
                                   FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                   FontSize="18" Foreground="#4FC3F7"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <TextBlock Text="Compass"
                                   FontSize="16" FontWeight="SemiBold"
                                   Foreground="#EAEAEA"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </ui:TitleBar.Header>
                <ui:TitleBar.TrailingContent>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                        <Button Content="⟳  Sync"
                                Command="{Binding SyncCommand}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"
                                Background="#4FC3F7" Foreground="#0A0A0A"
                                FontWeight="SemiBold" FontSize="13"
                                Padding="14,6" BorderThickness="0"
                                Cursor="Hand" Margin="0,0,12,0"
                                VerticalAlignment="Center">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="6"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                        <TextBlock Text="{Binding StatusText}"
                                   Foreground="#8A8A8A" FontSize="12"
                                   VerticalAlignment="Center" MaxWidth="320"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </ui:TitleBar.TrailingContent>
            </ui:TitleBar>
        </Border>

        <!-- ═══ MISSING-KEYS BANNER (visible only when MissingSecrets is non-empty) ══ -->
        <Border Grid.Row="1"
                Margin="16,0,16,8"
                Padding="14,10"
                Background="#0D1A22"
                BorderBrush="#4FC3F7"
                BorderThickness="1"
                CornerRadius="6">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding MissingSecrets.Count}" Value="0">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel>
                <TextBlock Text="Add your Steam / IGDB API keys to sync — see README"
                           Foreground="#4FC3F7" FontSize="13" FontWeight="SemiBold"
                           Margin="0,0,0,4"/>
                <ItemsControl ItemsSource="{Binding MissingSecrets}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock FontSize="11" Foreground="#8A8A8A">
                                <Run Text="• "/>
                                <Run Text="{Binding}"/>
                            </TextBlock>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!-- ═══ MAIN CONTENT ══════════════════════════════════════════════ -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                      Background="#0A0A0A" Padding="16,0">
            <StackPanel>
                <!-- Section header: Recommendations -->
                <TextBlock Text="Recommended from your backlog"
                           Foreground="#EAEAEA" FontSize="14" FontWeight="SemiBold"
                           Margin="0,8,0,12"/>

                <!-- Empty-state message (when no recs) -->
                <TextBlock Foreground="#5F5F5F" FontSize="13" Margin="0,0,0,16"
                           Text="No recommendations yet — sync your library to get started.">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Recommendations.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- Recommendations card grid (WrapPanel so cards wrap responsively) -->
                <ItemsControl ItemsSource="{Binding Recommendations}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:RecommendationRow}">
                            <!-- Recommendation card -->
                            <Border Margin="0,0,10,10"
                                    Width="210"
                                    Background="#141414"
                                    BorderBrush="#242424" BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="10,10,12,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Gold score ring -->
                                    <controls:ScoreRing Grid.Column="0"
                                                        Percent="{Binding ScorePercent}"
                                                        Margin="0,0,10,0"
                                                        VerticalAlignment="Top"/>

                                    <!-- Text content -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Top">
                                        <TextBlock Text="{Binding Name}"
                                                   Foreground="#EAEAEA" FontSize="13"
                                                   FontWeight="Medium"
                                                   TextWrapping="Wrap"
                                                   LineHeight="18"/>
                                        <TextBlock Text="{Binding FeatureLine}"
                                                   Foreground="#8A8A8A" FontSize="11"
                                                   TextWrapping="Wrap"
                                                   Margin="0,3,0,0"
                                                   LineHeight="15">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding FeatureLine}" Value="">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Text="{Binding Why}"
                                                   Foreground="#5F5F5F" FontSize="11"
                                                   TextWrapping="Wrap"
                                                   Margin="0,3,0,0"
                                                   FontStyle="Italic"
                                                   LineHeight="15"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Unmatched section -->
                <Expander IsExpanded="False" Margin="0,16,0,8"
                          Background="Transparent" BorderThickness="0">
                    <Expander.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Foreground="#8A8A8A" FontSize="13">
                                <Run Text="Unmatched ("/>
                                <Run Text="{Binding Unmatched.Count, Mode=OneWay}"/>
                                <Run Text=")"/>
                            </TextBlock>
                        </StackPanel>
                    </Expander.Header>
                    <ItemsControl ItemsSource="{Binding Unmatched}" Margin="0,8,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:GameRow}">
                                <TextBlock Text="{Binding Name}"
                                           Foreground="#5F5F5F" FontSize="12"
                                           Margin="0,2"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Expander>
            </StackPanel>
        </ScrollViewer>

        <!-- ═══ FOOTER ════════════════════════════════════════════════════ -->
        <Border Grid.Row="3" Background="#0D0D0D" BorderBrush="#222" BorderThickness="0,1,0,0"
                Padding="16,6">
            <TextBlock Foreground="#5F5F5F" FontSize="11">
                <Run Text="Backlog ("/>
                <Run Text="{Binding Recommendations.Count, Mode=OneWay}"/>
                <Run Text=") · Unmatched ("/>
                <Run Text="{Binding Unmatched.Count, Mode=OneWay}"/>
                <Run Text=")"/>
            </TextBlock>
        </Border>
    </Grid>

    <ui:FluentWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <local:InverseBoolConverter x:Key="InverseBoolConverter"
                                    xmlns:local="clr-namespace:Compass.App"/>
    </ui:FluentWindow.Resources>
</ui:FluentWindow>
