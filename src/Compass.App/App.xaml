<Application x:Class="Compass.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Compass.App"
             xmlns:ui="clr-namespace:Wpf.Ui.Markup;assembly=Wpf.Ui">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Dark" />
                <ui:ControlsDictionary />
            </ResourceDictionary.MergedDictionaries>
            <!-- Global converters available to all windows -->
            <local:InverseBoolConverter x:Key="InverseBoolConverter"/>
            <local:PathToImageConverter x:Key="PathToImageConverter"/>
            <local:FractionToWidthConverter x:Key="FractionToWidth"/>
            <local:NullToVisibilityConverter x:Key="NullToVis"/>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>

            <!-- Cap every page to the NavigationView content viewport. WPF-UI hosts pages inside a
                 DynamicScrollViewer that measures content with INFINITE height, which both defeats
                 list virtualization (all rows realized → multi-second freeze on a large library)
                 and leaves the page nothing of its own to scroll (dead mouse wheel). Binding
                 MaxHeight to that outer ScrollViewer's ViewportHeight bounds each page so its own
                 ListBox / ScrollViewer virtualizes and scrolls normally. -->
            <Style x:Key="NavPageStyle" TargetType="{x:Type Page}">
                <Setter Property="MaxHeight"
                        Value="{Binding ViewportHeight, RelativeSource={RelativeSource AncestorType={x:Type ScrollViewer}}}"/>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
